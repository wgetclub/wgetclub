# =========================================================================
# COPY TO contracts/.env AND FILL IT IN. Copying without filling it in does NOT
# work: the values below are deliberately invalid placeholders.
#
# If you leave YOUR_KEY in the URL, Alchemy answers
#   HTTP 401 {"message":"Must be authenticated!"}
# — which tells you nothing about the cause. This is the cause.
#
# If you leave REGISTRY_OWNER at 0x000...0, the contract NOW refuses to deploy
# (ZeroAddress). It used to deploy, and the result was an ownerless registry:
# withdraw() unreachable, all the revenue locked away forever.
# =========================================================================

# ---------------------------------------------------------------------------
# contracts/.env — used by `forge script`
# ---------------------------------------------------------------------------

# To DEPLOY, the public RPC is enough and needs no key:
#   BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# It is rate-limited, and that matters for the resolver's cold path (which runs on
# every cache miss) — not for a one-off transaction. Use the Alchemy key when you
# configure the Workers; for the deploy, the public one does the job.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org

# Optional. Without it, drop --verify from the forge script: the deploy works, the
# contract just doesn't get verified on the explorer.
BASESCAN_API_KEY=

# REQUIRED, and there is no safe default. The contract reverts if they are zero.
#
# REGISTRY_OWNER is who can withdraw the revenue, adjust the price and release
# reserved names. It is the only account that can, and it cannot be changed after
# deploy. Use the address `cast wallet list` shows for your deploy key — or a
# multisig, if you plan to take this seriously.
REGISTRY_OWNER=
ROYALTY_RECEIVER=

# ---------------------------------------------------------------------------
# Workers — local dev only (apps/*/.dev.vars). In production these are secrets:
#   npx wrangler secret put BASE_RPC_URL --name wgetclub-resolver
# NEVER in wrangler.toml — that file is committed.
# ---------------------------------------------------------------------------

# HERE the public RPC will NOT do. This is the resolver's cold path: every cache miss
# goes through it, and the public rate limit drops you exactly at launch, when the
# cache is empty. Use Alchemy/QuickNode.
# BASE_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY_HERE

# Pinata JWT — this is what pays for the pinning. A leak means someone pinning on
# your account. See docs/SECURITY.md.
PINATA_JWT=

# HMAC key for the SIWE session cookies.  openssl rand -hex 32
SESSION_SECRET=

# Addresses allowed to call /api/admin/* (abuse takedown).
ADMIN_ADDRESSES=
